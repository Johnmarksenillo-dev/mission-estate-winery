{% render 'text', block: block %}

{% schema %}
{
  "name": "Text",
  "tag": null,
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "t:html_defaults.share_information_about_your"
    },
    {
      "type": "header",
      "content": "Line clamp"
    },
    {
      "type": "range",
      "id": "line_clamp",
      "label": "Line clamp",
      "min": 0,
      "max": 10,
      "step": 1,
      "default": 0
    },
    {
      "type": "text",
      "id": "see_more_text",
      "label": "See more button",
      "default": "SEE MORE",
      "visible_if": "{{ block.settings.line_clamp > 0 }}"
    },
    {
      "type": "text",
      "id": "see_less_text",
      "label": "See less button",
      "default": "SEE LESS",
      "visible_if": "{{ block.settings.line_clamp > 0 }}"
    },
    {
      "type": "checkbox",
      "id": "show_arrow",
      "label": "Show arrow",
      "default": false,
      "visible_if": "{{ block.settings.line_clamp > 0 }}"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "options": [
