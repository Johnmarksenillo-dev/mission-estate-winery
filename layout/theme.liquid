  <script src='https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js'></script>
  <script>
    emailjs.init('pDluBnzXhuQFTKShr'); // Replace with your real public key from EmailJS
  </script>

  <script>
    {% comment %} const enquiryButtons = document.querySelectorAll('.open-enquiry-popup');
    const popup = document.getElementById('enquiryPopup');
    const closeBtn = document.querySelector('.close-popup');
    const formContent = document.getElementById('formContent');
    const successMessage = document.getElementById('successMessage');
    const closeSuccess = document.getElementById('closeSuccess'); {% endcomment %}

    // Enquiry Form
    const form = document.getElementById('enquiryForm');

    const enquiryButtons = document.querySelectorAll('.open-enquiry-popup');
    const popup = document.getElementById('enquiryPopup');
    const closeBtn = document.querySelector('.close-popup');
    const formContent = document.getElementById('formContent');
    const successMessage = document.getElementById('successMessage');
    const closeSuccess = document.getElementById('closeSuccess');

    const functionEmails = {
      "Cellar Door": "cellardoor@missionestate.co.nz",
      "Wedding": "functions@missionestate.co.nz",
      "Corporate": "functions@missionestate.co.nz",
      "Private Dining": "restaurant@missionestate.co.nz",
      "Other Function": "info@missionestate.co.nz"
    };


    const select = document.getElementById('functionType');

    select.innerHTML = '';

    Object.keys(functionEmails).forEach(key => {
      const option = document.createElement('option');
      option.value = key;
      option.textContent = key;
      select.appendChild(option);
    });

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      const formData = new FormData(form);
      const functionType = formData.get('function_type');
      const recipient = functionEmails[functionType] || 'info@missionestate.co.nz';
      // Map the display names to your URL slugs
      const successRedirects = {
        "Cellar Door": "cellar-door",
        "Wedding": "wedding",
        "Corporate": "corporate",
        "Private Dining": "private-dining",
        "Other Function": "thank-you"
      };
      const data = Object.fromEntries(formData.entries());
      data.to_email = recipient;
      console.log(successRedirects[functionType])
      emailjs.send('service_0yegj2l', 'template_1oo8vzr', data)
        .then(() => {
          const redirectUrl = successRedirects[functionType]  + '-thank-you' || 'thank-you';
          window.location.href = redirectUrl;
        })
        .catch((e) => {
          console.log(e);
          alert(e.text);
        }); 
    });

    // Open popup
    enquiryButtons.forEach(button => {
      button.addEventListener('click', () => {
        popup.style.display = 'block';
        formContent.style.display = 'block';
        successMessage.style.display = 'none';
      });
    });

    // Close popup
    closeBtn.addEventListener('click', () => {
      popup.style.display = 'none';
    });

    closeSuccess.addEventListener('click', () => {
      popup.style.display = 'none';
    });

    // Close when clicking outside the form
    window.addEventListener('click', function (event) {
      if (event.target === popup) {
        popup.style.display = 'none';
      }
    });

    // Detect successful form submission
    window.addEventListener('DOMContentLoaded', function () {
      const hash = window.location.hash;
      {% comment %} const shopifySuccess = document.querySelector('.shopify-message'); {% endcomment %}

      if (hash === '#enquiryPopup') {
        popup.style.display = 'block';
        formContent.style.display = 'none';
        successMessage.style.display = 'block';
      }
    });
  </script>

