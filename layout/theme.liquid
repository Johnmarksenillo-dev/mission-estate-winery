  <script>
    const checkReviews = setInterval(() => {
      const items = document.querySelectorAll('.grp-entangle-item');
      if (items.length) {
        items.forEach((item, index) => {
          const review = item.querySelector('.grp-entangle-item-body-review.truncated');
          if (review && review.textContent.trim() === '') {
            const outerDiv = item.closest('div[key]');
            if (outerDiv) {
              console.log(`Item ${index + 1}: Empty review found. Removing parent div[key].`);
              outerDiv.remove();
            } else {
              console.log(`Item ${index + 1}: No parent div[key] found.`);
            }
          }
        });
        clearInterval(checkReviews); // Stop polling after first batch is processed
      }
    }, 500);
  </script>
