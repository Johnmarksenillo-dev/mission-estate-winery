    "sustainability_mission_4UWqRE": {
      "type": "sustainability-mission",
      "name": "Sustainability Mission",
      "settings": {
        "section_id": "Sustainability-Mission",
        "main_heading": "Mission is a proud founding member of Sustainable Winegrowing New Zealand.",
        "button_text": "",
        "button_url": "#",
        "box_heading": "OUR COMMITMENT TO SUSTAINABILITY",
        "left_text": "As a proud founding member of Sustainable Winegrowing New Zealand (SWNZ), we’ve built a culture of care and accountability.  Our commitment is backed by independent certification and shaped by evolving standards.",
        "main_image": "shopify://shop_images/Artwork28_a5853760-486d-4543-b656-94b02b590fb8.png",
        "description": "We’ve held ISO14001 environmental certification since 1998, and regularly review our practices to ensure our sustainability goals are met – and exceeded.\n\n<h2>Minimising our impact across the business</h2>\nEvery part of our wine production – from vineyard to bottling – is carefully managed to reduce environmental impact.\nOur winery was purpose-built for maximum energy and water efficiency, and in 2007 underwent a major upgrade to further enhance sustainability. In 2023, we installed 63kW of solar panels, and in 2024, we planted 52,000 native trees on the property as part of our reforestation efforts.\nBy applying thoughtful technology and science, we’re able to reduce our environmental impact while staying true to our winemaking tradition.\nThe current production facility has been designed to deliver maximum energy and water efficiencies which is a vital element in our ongoing commitment to the environment.<br><br>",
        "button_1_url": "#",
        "button_1_text": ""
      }
    },
