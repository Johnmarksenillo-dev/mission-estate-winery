            "accordion_content": "<div class=\"wrapper_flex-menu\">\n  <div class=\"menu\">\n     <p class=\"name\">Marmite Bread, Smoked Butter, Honeycomb</p>\n   </div>\n\n <div class=\"menu\">\n     <p class=\"name\">Fried Chicken, Creamy “Yum Yum” Sauce, Parmesan</p>\n   </div>\n\n <div class=\"menu\">\n     <p class=\"name\">Potato Doughnut, Sour Cream</p>\n   </div>\n</div>",
            "accordion_heading1": "ADD-ON",
            "accordion_content1": "<div class=\"wrapper_flex-menu\">\n <div class=\"menu\">\n     <p class=\"name\">Te Matuku Oyster, Chardonnay Mignonette </p>\n<p class=\"price_quantity\">6ea</p>\n   </div>\n</div>",
            "accordion_heading2": "ENTRÉE",
            "accordion_content2": "<div class=\"wrapper_flex-menu\">\n  <div class=\"menu\">\n     <p class=\"name\">Spiced Green Lip Mussels, Ginger Beer&Coconut Broth, Garlic Bread</p>\n   </div>\n\n <div class=\"menu\">\n     <p class=\"name\">Feta & Corn Fritters, Spiced Lentil Curry, Buffalo Curd, Soft Egg</p>\n   </div>\n\n <div class=\"menu\">\n     <p class=\"name\">Chicken & Leek Pie, Crackling Crust, Apple& Walnut Salad</p>\n   </div>\n\n</div>",
            "accordion_heading3": "MAIN",
            "accordion_content3": "<div class=\"wrapper_flex-menu\">\n  <div class=\"menu\">\n     <p class=\"name\">Holly’s Pork Sausages, Seeded Mash, Crushed Peas, Braised Onion Gravy</p>\n   </div>\n\n <div class=\"menu\">\n     <p class=\"name\">Beef Bourguignon, Burnt Butter Mash, Seasonal Vegetables</p>\n   </div>\n\n <div class=\"menu\">\n     <p class=\"name\">Te Mata Mushroom Risotto, Smoked Potato, Golden Raisin Salsa</p>\n   </div>\n\n</div>",
