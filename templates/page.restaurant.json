            "accordion_content4": "<div class=\"wrapper_flex-menu\">\n  <div class=\"menu\">\n     <p class=\"name\">Hawke’s Bay Caught Fish, Sesame Crumbed Whole Prawn, Cauliflower, Saffron Poached Potato, Almond\n</p>\n   </div>\n\n <div class=\"menu\">\n     <p class=\"name\">Medium Rare Scotch Fillet, Duck Fat Mash Potato, Spring Greens, Shiitake Jus, Béarnaise</p>\n   </div>\n\n <div class=\"menu\">\n     <p class=\"name\">Pecorino, Mint & Pea Risotto, Mozzarella, Roasted Pear, Fig & Honey, Rocket</p>\n   </div>\n\n   <div class=\"menu\">\n     <p class=\"name\">Shared Seasonal Market Vegetables, Orange Vinaigrette</p>\n   </div>\n</div>",
            "accordion_heading5": "BYO CAKE SERVICE",
            "accordion_content5": "<div class=\"wrapper_flex-menu\">\n  <div class=\"menu\">\n     <p class=\"name\">Self Service Cake Charge</p>\n     <p class=\"price_quantity\">$30.00</p>\n   </div>\n\n <div class=\"menu\">\n     <p class=\"name\">Restaurant Service Plated Cake Charge</p>\n     <p class=\"price_quantity\">$5.00pp</p>\n   </div>\n\n<div class=\"menu\">\n     <p class=\"name\">Restaurant Service Plated Cake Charge with Vanilla Bean Ice Cream & Coulis</p>\n     <p class=\"price_quantity\">$7.00pp</p>\n   </div>\n\n<div class=\"note_wraps\">\n  <p>Note: This is a sample menu and subject to variations based on seasonal availability</p>\n  <p>All guests must dine off the same menu</p>\n  <p>Dietary requirements are catered for by prior arrangement</p>\n</div>\n</div>",
            "accordion_heading6": "MAIN",
            "accordion_content6": "<div class=\"wrapper_flex-menu\">\n  <div class=\"menu\">\n     <p class=\"name\">Hawke’s Bay Caught Fish, Sesame Crumbed Whole Prawn, Cauliflower, Saffron Poached Potato, Almond\n</p>\n   </div>\n\n <div class=\"menu\">\n     <p class=\"name\">Medium Rare Scotch Fillet, Duck Fat Mash Potato, Spring Greens, Shiitake Jus, Béarnaise</p>\n   </div>\n\n <div class=\"menu\">\n     <p class=\"name\">Pecorino, Mint & Pea Risotto, Mozzarella, Roasted Pear, Fig & Honey, Rocket</p>\n   </div>\n\n   <div class=\"menu\">\n     <p class=\"name\">Shared Seasonal Market Vegetables, Orange Vinaigrette</p>\n   </div>\n</div>",
            "accordion_heading7": "DESSERT",
            "accordion_content7": "<div class=\"wrapper_flex-menu\">\n  <div class=\"menu\">\n     <p class=\"name\">Elderflower & Boysenberry Crème Brulée, Lemon Poppyseed Cake, Blanc Mousse</p>\n   </div>\n\n <div class=\"menu\">\n     <p class=\"name\">72% Chocolate Crèmeux, Orange Ginger Sablé, Orange Mousse, Pâte de Fruit</p>\n   </div>\n\n <div class=\"menu\">\n     <p class=\"name\">Mission Tiramisu, Espresso Sponge, Brandy Mascarpone, Espresso Anglaise</p>\n   </div>\n\n</div>",
            "accordion_heading8": "BYO CAKE SERVICE",
            "accordion_content8": "<div class=\"wrapper_flex-menu\">\n  <div class=\"menu\">\n     <p class=\"name\">Self Service Cake Charge</p>\n     <p class=\"price_quantity\">$30.00</p>\n   </div>\n\n <div class=\"menu\">\n     <p class=\"name\">Restaurant Service Plated Cake Charge</p>\n     <p class=\"price_quantity\">$5.00pp</p>\n   </div>\n\n<div class=\"menu\">\n     <p class=\"name\">Restaurant Service Plated Cake Charge with Vanilla Bean Ice Cream & Coulis</p>\n     <p class=\"price_quantity\">$7.00pp</p>\n   </div>\n\n<div class=\"note_wraps\">\n  <p>Note: This is a sample menu and subject to variations based on seasonal availability</p>\n  <p>All guests must dine off the same menu</p>\n  <p>Dietary requirements are catered for by prior arrangement</p>\n</div>\n</div>",
