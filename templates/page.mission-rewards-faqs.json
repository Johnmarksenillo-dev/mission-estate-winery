        "collapsible_row_BpQtdB": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What happened to my wallet balance from the old rewards programme?",
            "icon": "none",
            "row_content": "<p><em>If you previously had a wallet balance, it was converted to ‘Mission Checkout $’ via a unique code emailed to you when the new system launched. Codes remain valid for three years from the email date.</em></p>",
            "page": ""
          }
        },
        "collapsible_row_jVgYJF": {
          "type": "collapsible_row",
          "disabled": true,
          "settings": {
            "heading": "How long do I have to use my wallet balance?",
            "icon": "none",
            "row_content": "<p>Wallet balances from the old programme will remain active for 12 months after the changeover. Be sure to use them before they expire!</p>",
            "page": ""
          }
        },
        "collapsible_row_LTFMHA": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How long do I have to use my wallet balance?",
            "icon": "none",
            "row_content": "<p><em>Wallet codes from the old programme remain valid for three years from the launch of the new system. Be sure to use them before they expire.</em></p>",
            "page": ""
          }
        },
        "collapsible_row_nDXNa9": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Why did you remove the tier system?",
            "icon": "none",
            "row_content": "<p><em>Customer feedback told us the old tier system felt complicated and slow to reward. The new programme is simpler, clearer, and more rewarding from the start — so you enjoy benefits sooner, without climbing levels.</em></p>",
            "page": ""
          }
        },
        "collapsible_row_Trhkhq": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What happened to the Mission Status Points I had earned?",
            "icon": "none",
            "row_content": "<p><em>Any vouchers you had earned have been uploaded to your new account. Status Points themselves weren’t transferred, as they only related to tier progress. Log in to your Mission Rewards account to view your discount codes. All vouchers will be honoured, but must be redeemed within three years of the new programme launch.</em></p>",
            "page": ""
