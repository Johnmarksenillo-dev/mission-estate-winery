          "type": "collapsible_row",
          "settings": {
            "heading": "What’s changed in the new Mission Rewards programme?",
            "icon": "none",
            "row_content": "<p><em>It’s simpler. No more tiers — just easy-to-earn points, exclusive perks, and straightforward redemptions</em></p>",
