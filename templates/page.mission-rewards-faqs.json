    "collapsible_content_i8cb7W": {
      "type": "collapsible-content",
      "blocks": {
        "collapsible_row_fec9XE": {
          "type": "collapsible_row",
          "settings": {
            "heading": " How do I earn points?",
            "icon": "none",
            "row_content": "<p><em>Sign up for Mission Rewards online — it’s free and easy. Simply enter your name, email, and a password to get started.</em></p>",
            "page": ""
          }
        },
        "collapsible_row_UL6YKR": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How many Mission Reward Points will I earn?",
            "icon": "none",
            "row_content": "<p><em>Earn 1 point for every $1 spent on cases purchased online or at our Cellar Door. You can also earn bonus points for following us on social media or referring friends. Be sure you’re logged in when you purchase.</em></p>",
            "page": ""
          }
        },
        "collapsible_row_B89LnD": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How do I redeem my points?",
            "icon": "none",
            "row_content": "<p><em>Once you reach 400 points, you can redeem them for discounts online or at the Cellar Door. To redeem online, click the blue Mission Rewards button at the bottom right of our website, select ‘Mission Checkout $,’ and you’ll receive a reward code by email. Add a case of wine or two to your cart and enter the code at checkout to apply your discount</em></p>",
            "page": ""
          }
        },
        "collapsible_row_Nmwzdx": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Do my points expire?",
            "icon": "none",
            "row_content": "<p><em>Yes. Points expire two years after they are earned. We’ll send you a reminder email one month before expiry. If your account is inactive for two years, your full balance will also expire.</em></p>",
            "page": ""
          }
        },
        "collapsible_row_Vf8T4E": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Can I use rewards on all products?",
            "icon": "none",
            "row_content": "<p><em>Rewards can be used on most wine purchases, though some exclusions may apply during promotions or limited releases. Vouchers can be redeemed online or at the Cellar Door.</em></p>",
            "page": ""
          }
        },
        "collapsible_row_aeTYni": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What happens if my friend doesn’t complete a purchase?",
            "icon": "none",
            "row_content": "<p><em>Your referral reward is only issued once your friend places and completes their first order.</em></p>",
            "page": ""
          }
        },
        "collapsible_row_j4dFgQ": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Do I need to become a member to buy wine?",
            "icon": "none",
            "row_content": "<p><em>No. You’re welcome to checkout as a guest.</em></p>",
            "page": ""
          }
        },
        "collapsible_row_d3CTa4": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What if I forget to log in when I buy wine online?",
            "icon": "none",
            "row_content": "<p><em>If you use your usual email address at checkout, your points will be added automatically.</em></p>",
            "page": ""
          }
        },
        "collapsible_row_zdrhgY": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What if I forget to log in when I buy wine at the cellar door?",
            "icon": "none",
            "row_content": "<p><em>If you forget to give your email at the Cellar Door, email us at info@missionestate.co.nz with your receipt image, and we’ll add the points manually.</em></p>",
            "page": ""
          }
        },
        "collapsible_row_VCQwwE": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How do I change my email address and password?",
            "icon": "none",
            "row_content": "<p><em>To change your password, click ‘Forgot Password’ on the login screen. To update your email address, contact us at </em><a href=\"mailto:info@missionestate.co.nz\" title=\"mailto:info@missionestate.co.nz\"><em>info@missionestate.co.nz</em></a><em>.</em></p>",
            "page": ""
          }
        },
        "collapsible_row_CzLPPh": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Can I gift or transfer my points to someone else?",
            "icon": "none",
            "row_content": "<p><em>No. Mission Rewards points can’t be transferred, but you can gift wine once redeemed.</em></p>",
            "page": ""
          }
        }
