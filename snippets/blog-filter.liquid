

{% if blog.tags.size > 0 %}
<div class="blog-filter">
  <div class="list-group">
    <ul id="BlogTagFilter" class="tag-list">
      <li>Filter by:</li>
      <li> <a href="{{ blog.url }}" class="button"> All  </a></li>
      {% for tag in blog.all_tags %}
      <li> <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="button"> {{ tag }} </a></li>
      {% endfor %}
    </ul>
  </div>
</div>
{% endif %}
<style>
  .list-group {
  text-align: center;
}


  select#sort_by{
    background-color: #ddd9d9;
    font-family: 'Raleway';
  }

ul#BlogTagFilter {
  list-style: none;
    padding-top: 10px;
    margin-top: 0px;
    text-align: left;
    padding-left: 0px;
}
ul#BlogTagFilter a.button {
    background-color: #ddd9d9 !important;
    font-size: 18px;
    font-family: Raleway;
    color: #002855;
    border: none;
    padding: 0px;
    text-align: left;
    display: block;
    margin: 18px 0px 0px;
    padding: 11px 20px;
    border-radius: 12px;
}
ul#BlogTagFilter li {
    display: block;
    margin: 5px 0px;
    font-size: 24px;
    font-weight: 600;
  color: #002855;
  font-family: 'Raleway';
}

  ul#BlogTagFilter li:first-child{
       text-transform: uppercase;
  }
  .sort-by {
  margin-bottom: 20px;
}

.sort-by label {
  font-weight: bold;
  margin-right: 5px;
}

.sort-by select {
  padding: 5px;
  border-radius: 5px;
  border: 1px solid #ccc;
}


</style>

