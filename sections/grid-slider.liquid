      "default": "#002855"
    },
    {
      "type": "color",
      "label": "Button1 Text Color",
      "id": "button1_color",
      "default": "#fff"
    },
    {
      "type": "color",
      "label": "Button2 Background Color",
      "id": "button2_bg_color",
      "default": "#fff"
    },
    {
      "type": "color",
      "label": "Button2 Text Color",
      "id": "button2_color",
      "default": "#002855"
    },
    {
      "type": "header",
      "content": "Column 1 Settings"
    },
    {
      "type": "image_picker",
      "label": "Slider Image 1 (Column 1)",
