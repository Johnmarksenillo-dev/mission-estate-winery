{% style %}
   .{{ section.id }} .custom-slideshow-section {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
   }
@media screen  and (min-width: 769px) {
  .{{ section.id }} .custom-slideshow-section {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  }
}

  .{{ section.id }} .heading{
    color:{{section.settings.heading_color}};
        font-size: 38px;
    font-weight: 600;
  }
  .{{ section.id }} .text{
    color:{{section.settings.text_color}};
    font-weight: 300 !important;
    font-size: 18px;
  }
 body.about-us .{{ section.id }} .text{
    color: rgb(0 40 85 / 75%);
    font-size: 18px;
  }
  .{{ section.id }} a.button--primary{
    background-color:{{section.settings.button1_bg_color}};
    color:{{section.settings.button1_color}};
    border:1px solid {{section.settings.button1_color}};
    width:fit-content;
            font-size: 18px;
    font-weight: 400;
  }
  .{{ section.id }} a.button--secondary{
    background-color: rgba(0,0,0,0);
    color: #ffffff;
    border: none;
    width: auto;
    padding: 0px;
    text-decoration: underline;
    text-underline-offset: 8px;
        font-size: 18px;
    font-weight: 400;
  }
{% endstyle %}
 
<div id="{{ section.settings.section_id }}" class="{{ section.id }} {% if section.settings.slider_class != blank %} {{ section.settings.slider_class }} {% endif %}">
  <div class="custom-slideshow-section" style="{% if section.settings.bgimage != blank %} background-image: url('{{ section.settings.bgimage | img_url: 'master' }}'); {% endif %}">
    <div class="{% if section.settings.enable_fullwidth %}container{% else %}page-width{% endif %}">
      <div class="row {% if section.settings.image_position == 'right' %}col-reverse{% endif %}">
        {% if section.settings.enable_slideshow %}
          <div class="col">
            <div class="slideshow-wrapper">
              {% assign image_count = 1 %}
              <div class="slick-slider" id="slick-slider-{{ section.id }}">
                {% for i in (1..5) %}
                  {% assign image_key = "slideshow_image_" | append: i %}
                  {% assign image = section.settings[image_key] %}
                  {% if image %}
                    <div>
                      <img src="{{ image | img_url: '1024x1024' }}" alt="Slide Image {{ i }}">
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          </div>
        {% endif %}
        
        <div class="col text-col-wrapper">
          <div class="text-col">
            {% if section.settings.heading %}
             <a href="{{ section.settings.heading_url }}" target="_blank" > <h2 class="heading color-blue font-size-44 line-height-40 font-glare-light m-0 pb-26">{{ section.settings.heading }}</h2> </a>
            {% endif %}
            {% if section.settings.text %}
                <div class="text font-size-18 font-sans-light pb-26" style="line-height:1.5em;">
                  {{ section.settings.text }}
                </div>            {% endif %}
            <div class="text-col text-col-buttons">
            <div class="buttons">
              {% if section.settings.button_1_url %}
                <a href="{{ section.settings.button_1_url }}" target="{{ section.settings.link_target1 }}" class="button button--primary{% if section.settings.simple_link1 %} no-button-border{% endif %} {% if section.settings.button_class != blank %} {{ section.settings.button_class }} {% endif %}">{{ section.settings.button_1_text }}</a>
              {% endif %}
              {% if section.settings.button_2_url %}
                <a href="{{ section.settings.button_2_url }}" target="{{ section.settings.link_target2 }}" class="button button--secondary{% if section.settings.simple_link2 %} no-button-border{% endif %} {% if section.settings.button_class2 != blank %} {{ section.settings.button_class2 }} {% endif %}">{{ section.settings.button_2_text }}</a>
              {% endif %}
            </div>
            {% if section.settings.secondary %}
            <div class="secondary-buttons">
              {% if section.settings.button_3_url %}
                <a href="{{ section.settings.button_3_url }}" target="{{ section.settings.link_target3 }}" class="button button--secondary {% if section.settings.simple_link3 %} no-button-border {% endif %}font-size-14 line-height-120 font-sans-light {% if section.settings.button_class3 != blank %} {{ section.settings.button_class3 }} {% endif %}">{{ section.settings.button_3_text }}</a>
              {% endif %}
              {% if section.settings.button_4_url %}
                <a href="{{ section.settings.button_4_url }}" target="{{ section.settings.link_target4 }}" class="button button--secondary {% if section.settings.simple_link4 %} no-button-border {% endif %}font-size-14 line-height-120 font-sans-light {% if section.settings.button_class4 != blank %} {{ section.settings.button_class4 }} {% endif %}">{{ section.settings.button_4_text }}</a>
              {% endif %}
            </div>
            {% endif %}
          </div>
          </div>
          
        </div>
      
      </div>
    </div>
  </div>
</div>
