<!-- Your custom script -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    $('.slick-slider').slick({
      infinite: true,
      slidesToShow: 1,
      slidesToScroll: 1,
      autoplay:  {{ section.settings.autoplay | json }},
      autoplaySpeed:  {{ section.settings.autoplay_speed }},
      speed: {{ section.settings.slide_speed }},
      arrows: false,
      dots: true
    });
  });
</script>

