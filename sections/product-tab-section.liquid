{% schema %}
{
  "name": "Product Tabs",
  "class": "customProduct_tabs",
  "settings": [],
  "blocks": [
    {
      "type": "image",
      "name": "add block",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Subtitle"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Tabs",
    }
  ]
}
{% endschema %}

<div class="tabs-container CustomProducts_tab page-width" id="product_tabs_starts">
  <!-- Tab Titles -->
  <ul class="tab-links">
   {% assign compare = product.metafields.custom.product_tabs.value %} 
    {% for compare in compare %}
      <li class="{% if forloop.first %}active{% endif %}">
      <a class="wrap_compare_link" href="{{ compare.tab_link }}">  {{ compare.tab_name }}</a>
      </li>
   {% endfor %}
  </ul>

  <!-- Tab Content -->
  <div class="tab-content">
    {% assign tab_content = product.metafields.custom.tab_content.value %}
    {% for tab_content in tab_content %}
      <div class="tab {% if forloop.first %}active{% endif %} custonmainatbs">
        <div class="Commantab_C LeftSide">
          <div class="HedingCont_wrap">
            <div class="MainHeading">{{ tab_content.heading }}</div>
             <div class="SubHeading">{{ tab_content.sub_heading }}</div>
          </div>
          <div class="BoxDesc">
            {{ tab_content.box_description }}
          </div>
          <div class="MainDescreiption">
            {{ tab_content.main_description }}
          </div>
          <!-- <div class="NewFleicon_dvs">

                  {% assign feature = product.metafields.custom.product_feature.value  %}
                    {% for feature in feature %}
                     
                   
                  <div class="wraps_inner-icons NewInner_wrap">
                      <div class="inner_wrapper-texts NewWrapper_Text">
                        <div class="wrapper_innericon NewWrap_innericon">
                            <img src="{{ feature.image | img_url: 'master' }}" alt="wine">
                        </div>
                         <div class="wrapper_textdes NewWrapper_Textdes">
                            <p class="textpercent NewTextPrecent"> {{ feature.subtitle  }} </p>
                            <h4>{{ feature.title  }}</h4>      
                         </div> 
                      </div>
                  </div>
                   {% endfor %}
                </div> -->
        {%- if product.metafields.custom.product_feature_heading != blank -%}
          <h3 class="wraos_foodparing_headings">{{ product.metafields.custom.product_feature_heading }}</h3>
         {%- endif -%}

          {% assign food_pairing = product.metafields.custom.product_food_pairing.value %}
        <div class="food-icon-wrapper mb-30">
        {% for food_pairing in food_pairing %}
          <div class="food-pairing-icon font-size-18 line-height-120 font-sans-light color-grey">
             {% assign gallery = food_pairing.icon.value %}
           {%- if gallery != blank -%}
            <img class="wrap_icon" src="{{ gallery | img_url }}" alt="{{ gallery.alt }}"> {% endif %} {{ food_pairing.text }}
          </div>
       {% endfor %}
        </div>
          
      {%- if product.metafields.custom.product_feature_text != blank -%}
        <p class="eraps_productfeature_texts">{{ product.metafields.custom.product_feature_text }}</p>
      {%- endif -%}

          <div class="wraps_icons_textsblock NewFleicon_dvs">   
     {% for block in section.blocks %}
       {%- if block.settings.title != blank -%}
      <div class="wraps_inner-icons NewInner_wrap wrapsinner{{forloop.index}}">
          <div class="inner_wrapper-texts NewWrapper_Text">
            <div class="wrapper_innericon NewWrap_innericon">
                <img src="{{ block.settings.icon_image | img_url: 'master' }}" alt="wine">
            </div>
             <div class="wrapper_textdes NewWrapper_Textdes">
                <p class="textpercent NewTextPrecent"> {{ block.settings.subtitle  }} </p>
                <div class="wraps_value-icon_texts">{{ block.settings.title  }}</div>      
             </div> 
          </div>
      </div>
   {% endif %}
     {% endfor %}
    </div>
        </div>
        <div class="Commantab_C RightSide">
          <div class="ImageTab">
            {% assign gallery = tab_content.image.value %}
          {% for image in gallery %}
          {% assign image_url = image | img_url: '500x' %}
          <img src="{{ image_url }}" >
          {% endfor %}
          </div>
          
        </div>
      </div>
    {% endfor %}
  </div>
</div>

