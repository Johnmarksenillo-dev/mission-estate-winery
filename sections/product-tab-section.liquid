<style>

.CustomProducts_tab ul.tab-links li {
    margin-top: 30px;
}
.CustomProducts_tab .tab-content .tab {
  display: none;
}
.CustomProducts_tab .tab-content .tab.active {
  display: block;
}
  .tabs-container.CustomProducts_tab {
    display: flex;
        padding-bottom: 2rem;
}
  ul.tab-links {
    width: 20%;
}
 .customProduct_tabs {
    background: #ECEDE6;
    padding-top: 100px;
   padding-bottom: 95px;
}
ul.tab-links li {
    color: #002855;
    opacity: 1;
    font-size: 16px;
    cursor: pointer;
    font-family: 'Raleway';
}

  ul.tab-links li.active {
    color: #002855;
    opacity: 100%;
    list-style: none;
}

li.active:before {
    content: "";
    background: url("https://cdn.shopify.com/s/files/1/0738/5327/2315/files/Vector_b572bfd7-6e54-4a49-91ca-60e138b3f390.png?v=1738931787");
    background-repeat: no-repeat;
    background-position: center;
    background-size: contain;
    color: transparent;
    display: inline-block;
    height: 13px;
    width: 13px;
    position: relative;
    left: -3px;
}

ul.tab-links li.active {
    color: #002855;
    opacity: 100%;
    list-style: none;
    position: relative;
    left: -14px;
}

.MainHeading {
    font-size: 36px;
    color: #002855;
    font-family: 'Raleway';
    text-transform: uppercase;
}
 

.SubHeading {
    font-size: 20px;
    color: #002855d4;
    font-family: 'Raleway';
    font-weight: 600;
    padding-top: 5px;
}

   .tab-content {
    width: 80%;
}
.tab.active.custonmainatbs {
    display: flex !important;
    width: 100%;
}

.LeftSide {
    width: 50%;
}

.RightSide {
    width: 50%;
}
  .BoxDesc {
    background: transparent;
    padding: 30px 0px;
    width: 85%;
    font-size: 27px;
    line-height: 1.4em;
    border-radius: 8px;
    color: #002855;
    font-style: italic;
}
 .MainDescreiption {
    width: 90%;
    font-size: 16px;
    line-height: 1.9em;
    margin-top: 0px !important;
    color: #002855;
    font-family: 'Literata-light';
}
  
.NewFleicon_dvs {
    display: flex;
    margin-top: 0%;
    padding-bottom: 15px;
    width: 100%;
    flex-wrap: nowrap;
    justify-content: space-between;
}
  .NewTextPrecent {
    line-height: 1px;
        color: #002855 !important;
}
  .NewWrapper_Textdes h4 {
    color: #002855;
    font-size:18px;
}

div#product_tabs_starts a.wrap_compare_link {
    padding: 10px 0px !important;
    padding-left: 25px !important;
    position: relative;
    left: -25px;
}

  .CustomProducts_tab .tab-content .tab:first-child {
    display: flex;
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  let tabs = document.querySelectorAll(".tab-links li");
  let tabContents = document.querySelectorAll(".tab-content .tab");

  tabs.forEach(tab => {
    tab.addEventListener("click", function () {
      let target = this.getAttribute("data-tab");

      tabs.forEach(t => t.classList.remove("active"));
      tabContents.forEach(tc => tc.classList.remove("active"));

      this.classList.add("active");
      document.getElementById(target).classList.add("active");
    });
  });
});
</script>



